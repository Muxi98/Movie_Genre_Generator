from datasets import load_dataset
import torch

# 1. Define your master list of genres (adjust based on your dataset)
ALL_GENRES = ["Action", "Comedy", "Drama", "Horror", "Romance", "Sci-Fi", "Thriller"] 
GENRE_TO_IDX = {genre: idx for idx, genre in enumerate(ALL_GENRES)}

# 2. Load the dataset in streaming mode to protect your memory
# Replace "your_dataset_name" with the actual HuggingFace path
dataset = load_dataset("your_dataset_name", streaming=True)

# 3. Define the extraction mapping function
def extract_and_encode(sample):
    # Initialize a tensor of zeros for the multi-hot encoding
    target = torch.zeros(len(ALL_GENRES))
    
    # Flip the 0 to 1 for every genre present in this specific movie
    for genre in sample['genres']:
        if genre in GENRE_TO_IDX:
            target[GENRE_TO_IDX[genre]] = 1.0
            
    # Return ONLY the specific keys you requested
    return {
        "poster": sample["image"],       # The RGB image object
        "movie_name": sample["title"],   # The string title
        "encoded_genres": target         # The 1D PyTorch tensor
    }

# 4. Get the list of all original columns so we can delete them
# (In streaming mode, we pull this from the dataset features)
original_columns = list(dataset['train'].features.keys())

# 5. Apply the mapping and instantly drop the old columns
processed_dataset = dataset.map(
    extract_and_encode,
    remove_columns=original_columns
)

# Test the pipeline by pulling just the first movie
for movie in processed_dataset['train']:
    print(f"Title: {movie['movie_name']}")
    print(f"Target Tensor: {movie['encoded_genres']}")
    print(f"Poster Object: {movie['poster']}")
    break # Stop after one iteration to test
